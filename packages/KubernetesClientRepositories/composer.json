{
	"name": "wbrk-dev/kubeploy-kubernetes-client-repositories",
	"description": "Additional repositories for kubernetes-client.",
	"keywords": ["kubernetes", "docker", "container", "cluster"],
	"license" : "MIT",
    "repositories": [
        {
            "type": "path",
            "url": "../KubernetesClient"
        }
    ],
	"require": {
		"php"                   : "^7.4|^8.0",
		"php-http/client-common": "^2.0",
		"php-http/discovery"    : "^1.0",
		"illuminate/support"    : "^5.0|^6.0|^7.0|^8.0|^9.0|^10.0|^11.0|^12.0|^13.0",
		"ratchet/pawl"          : "^0.3",
		"symfony/yaml"          : "^4.0|^5.0|^6.0|^7.0",
		"softcreatr/jsonpath"   : "^0.5 || ^0.7 || ^0.8",
		"maclof/kubernetes-client": "dev-master"
	},
	"require-dev": {
		"phpunit/phpunit"            : "~7.0|~9.5",
		"mockery/mockery"            : "~1.2",
		"php-coveralls/php-coveralls": "~2.0",
		"php-http/socket-client"     : "^2.0",
		"nyholm/psr7": "^1.4"
	},
	"autoload": {
		"psr-4": {
			"WbrkDev\\KubernetesClientRepositories\\": "src/"
		}
	},
	"minimum-stability": "dev",
	"prefer-stable": true
}
